# ============================================================================
# VOKABEL-CHAMPION - ENVIRONMENT VARIABLES
# Kopiere diese Datei zu .env.local und fülle alle Werte aus
# ============================================================================

# DATABASE (Supabase PostgreSQL)
# Verwende den PostgreSQL Pooler für serverless (Render, Railway, etc.)
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_ID:YOUR_PASSWORD@aws-1-eu-central-1.pooler.supabase.com:6543/postgres

# AUTHENTICATION
# JWT Secret für Cookies und Session Management
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_change_this

# OAuth Configuration
# Falls OAuth/Manus aktiviert ist, hier die Server-URL eintragen
OAUTH_SERVER_URL=https://your-oauth-server.com
OWNER_OPEN_ID=your_owner_open_id

# App Configuration
# Eindeutige App-ID
VITE_APP_ID=vokabel-champion-prod

# Node Environment
NODE_ENV=production

# Optional: API Keys für Features
BUILT_IN_FORGE_API_URL=https://api.example.com
BUILT_IN_FORGE_API_KEY=your_api_key_here

# Optional: AWS S3 (falls File Storage benötigt)
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
